{% extends 'base.html.twig' %}

{% block body %}

{% for album in albums %}

    <h2>{{ album.albumTitle }}</h2>
    <a href="{{ path('album_show', {id: album.id}) }}"><img src="/images/{{ album.albumCover }}" width="200" height="200" ></a>
    <ul>
        {% for song in album.songs %}
            <li >{{ song.songTitle }} {{ (song.length / 60)|round(0, 'floor') }}:{{ '%02d'|format(song.length % 60) }} </li>
            <button onclick="selectSong('{{ song.songTitle }}', '{{ song.audioFile }}', '{{ album.albumCover }}')"> Play song </button>
            <button onclick="addToQueue('{{ song.songTitle }}', '{{ song.audioFile }}', '{{ album.albumCover }}')"> Add to queue </button>
            <a href="{{ path('song_show', {id: song.id}) }}"><button> Info </button></a>
        {% endfor %}
    </ul>

{% endfor %}

    <a href="{{ path('upload_album') }}">Upload Album</a>

{% endblock %}